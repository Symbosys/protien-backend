// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id          String    @id @default(uuid())
  firstName   String?
  lastName    String?
  email       String?   @unique
  phoneNumber String?   @unique
  password    String?
  role        Role      @default(CUSTOMER)
  dateOfBirth DateTime?
  gender      Gender?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart         Cart?
  wishlist     Wishlist[]
  orders       Order[]
  addresses    Address[]
  chatSessions ChatSession[]
  reviews      Review[]
}

enum Role {
  CUSTOMER
  ADMIN
}

enum Gender {
  FEMALE
  MALE
  OTHER
}

model Otp {
  id              BigInt    @id @default(autoincrement())
  phoneNumber     String    @unique
  otp             String
  expiresAt       DateTime
  attempts        Int       @default(0)
  lastAttemptedAt DateTime?
  isUsed          Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phoneNumber])
  @@map("otps")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  image       String?  @db.LongText
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subCategories SubCategory[] // One-to-many relation to SubCategorie
  products      Product[]
}

model SubCategory {
  id          String  @id @default(uuid())
  name        String
  description String
  image       String? @db.LongText
  categoryId  String // Foreign key to Categorie

  category Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([categoryId]) // Recommended index for performance
}

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  logo        String?  @db.LongText
  website     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@index([slug])
  @@index([isActive])
  @@map("brands")
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  image       String  @db.LongText
  images      Json? // Storage for multiple image URLs

  brandId           String?
  brand             Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  price             Decimal  @db.Decimal(15, 2)
  discountPrice     Decimal? @db.Decimal(15, 2)
  quantity          Int      @default(0)
  sku               String?
  cost              Decimal? @db.Decimal(15, 2)
  lowStockThreshold Int      @default(10)
  weight            Decimal? @db.Decimal(15, 2)
  weightUnit        String   @default("kg")
  status            String   @default("active")
  taxable           Boolean  @default(true)
  shippingRequired  Boolean  @default(true)
  seoTitle          String?
  seoDescription    String?  @db.Text
  seoKeywords       String?

  sizes  Json? // e.g. ["S", "M", "L"]
  colors Json? // e.g. ["Red", "Blue"]

  rating     Float @default(0)
  numReviews Int   @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  subCategoryId String?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartItems     CartItem[]
  variants      ProductVariant[]
  wishlistItems Wishlist[]
  orderItems    OrderItem[]
  analytics     ProductAnalytics?
  inventory     Inventory?
  reviews       Review[]
  offers        Offer[]

  @@index([categoryId])
  @@index([subCategoryId])
  @@index([brandId])
}

model Cart {
  id     String     @id @default(uuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id])
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id     String @id @default(uuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  quantity Int     @default(1)
  size     String?
  color    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model Attribute {
  id        String           @id @default(uuid())
  name      String           @unique
  values    AttributeValue[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model AttributeValue {
  id          String           @id @default(uuid())
  attributeId String
  attribute   Attribute        @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  image       String?          @db.LongText
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([attributeId, value])
  @@index([attributeId])
}

model ProductVariant {
  id              String           @id @default(uuid())
  productId       String
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku             String?          @unique
  price           Decimal          @db.Decimal(15, 2)
  discountPrice   Decimal?         @db.Decimal(15, 2)
  quantity        Int              @default(0)
  image           String?          @db.LongText
  attributeValues AttributeValue[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
}

model Wishlist {
  id        String  @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlists")
}

model SearchQuery {
  id        String   @id @default(uuid())
  query     String   @unique
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([query])
}

model Order {
  id          String   @id @default(uuid())
  orderNumber String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  addressId   String?
  address     Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  items OrderItem[]

  status        OrderStatus    @default(PENDING)
  paymentStatus PaymentStatus  @default(UNPAID)
  paymentMethod PaymentMethod?

  subtotal       Decimal @db.Decimal(15, 2)
  discount       Decimal @default(0) @db.Decimal(15, 2)
  shippingCharge Decimal @default(0) @db.Decimal(15, 2)
  tax            Decimal @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal @db.Decimal(15, 2)

  // Shipping address snapshot
  shippingName    String
  shippingPhone   String
  shippingAddress String
  shippingCity    String
  shippingState   String
  shippingPincode String
  longitude       String?
  latitude        String?

  note String? @db.Text

  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  cashfreeOrderId   String?
  cashfreePaymentId String?

  placedAt    DateTime  @default(now())
  shippedAt   DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([addressId])
  @@index([orderNumber])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  // Snapshot at time of purchase
  productName  String
  productImage String  @db.LongText
  size         String?
  color        String?

  quantity   Int
  unitPrice  Decimal @db.Decimal(15, 2)
  totalPrice Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum PaymentMethod {
  COD
  CARD
  RAZORPAY
  CASHFREE
}

model StoreAnalytics {
  id             String   @id @default(uuid())
  date           DateTime @unique // The day this entry represents
  totalSales     Decimal  @default(0.00) @db.Decimal(15, 2)
  totalOrders    Int      @default(0)
  totalReturns   Int      @default(0)
  totalCancelled Int      @default(0)
  visitsCount    Int      @default(0)

  onTimeDeliveries Int @default(0)
  lateDeliveries   Int @default(0)

  averageResponseTime Float @default(0.0) // In hours
  averageRating       Float @default(0.0)
  totalReviews        Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("store_analytics")
}

model ProductAnalytics {
  id        String  @id @default(uuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  viewsCount     Int     @default(0)
  addToCartCount Int     @default(0)
  purchaseCount  Int     @default(0)
  revenue        Decimal @default(0.00) @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_analytics")
}

model Inventory {
  id        String  @id @default(uuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity      Int     @default(0)
  lowStockAlert Int     @default(10)
  warehouseLoc  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("inventories")
}

// Marketing Models

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  description    String?      @db.Text
  discountType   DiscountType
  discountValue  Decimal      @db.Decimal(15, 2)
  minOrderAmount Decimal?     @db.Decimal(15, 2)
  maxDiscount    Decimal?     @db.Decimal(15, 2)
  startDate      DateTime?
  endDate        DateTime?
  usageLimit     Int?
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model Banner {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  imageUrl    String    @db.LongText
  linkUrl     String?
  position    String?
  isActive    Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([position])
  @@map("banners")
}

// Support Models

model ChatSession {
  id     String            @id @default(uuid())
  userId String?
  user   User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status ChatSessionStatus @default(ACTIVE)

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("chat_sessions")
}

enum ChatSessionStatus {
  ACTIVE
  CLOSED
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  sender MessageSender
  text   String        @db.LongText

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

enum MessageSender {
  USER
  AGENT
  SYSTEM
}

model Review {
  id      String       @id @default(uuid())
  rating  Int
  comment String       @db.Text
  reply   String?      @db.Text
  status  ReviewStatus @default(UNREPLIED)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}

enum ReviewStatus {
  REPLIED
  UNREPLIED
}

enum OfferType {
  FLAT_DISCOUNT
  PERCENTAGE_DISCOUNT
  MAKING_CHARGE_DISCOUNT
  FREE_GIFT
  CASHBACK
  EXCHANGE
  FESTIVAL
  BUY_ONE_GET_ONE_FREE
  GOLD_SAVINGS
  LOYALTY_REWARD
}

model Offer {
  id          String    @id @default(uuid())
  name        String // e.g., "Diwali Special", "20% Off Diamond"
  description String?   @db.Text
  offerType   OfferType

  // Value fields based on OfferType
  discountValue   Decimal? @db.Decimal(15, 2) // Flat amount, percentage, or making charge %
  minPurchase     Decimal? @db.Decimal(15, 2) // e.g., on purchases above 1,00,000
  giftDescription String? // e.g., "Free silver coin"
  cashbackDetails String? // e.g., "HDFC Credit Card 5% Cashback"
  exchangeDetails String? // e.g., "100% exchange value on old gold"

  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[] // Many-to-many with Product
}

model Blog {
  id         String   @id @default(uuid())
  title      String
  slug       String   @unique
  content    String   @db.LongText
  excerpt    String?  @db.Text
  image      String?  @db.LongText
  author     String   @default("Admin")
  tags       Json? // e.g. ["protein", "recipes", "fitness"]
  isActive   Boolean  @default(true)
  viewsCount Int      @default(0)
  readTime   Int? // in minutes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@map("blogs")
}

model WebConfig {
  id               String   @id @default(uuid())
  // Business Profile
  storeName        String   @default("")
  businessEmail    String   @default("")
  phoneNumber      String   @default("")
  website          String?
  storeDescription String?  @db.Text
  logo             String?  @db.LongText

  // Banking Details
  bankName          String?
  accountHolderName String?
  accountNumber     String?
  routingNumber     String?

  // GST & Tax Info
  gstNumber              String?
  panNumber              String?
  registeredBusinessName String?

  // Pickup Addresses (Stored as structured JSON array of address objects)
  pickupAddresses Json?

  @@map("web_configs")
}

model Address {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  mobile    String
  pincode   String
  locality  String?
  address   String      @db.Text
  city      String
  state     String
  longitude Float?
  latitude  Float?
  type      AddressType @default(HOME)
  isDefault Boolean     @default(false)


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

enum AddressType {
  HOME
  WORK
  OTHER
}
